# ── LLM Provider ─────────────────────────
# Options: ollama | openai | anthropic
LLM_PROVIDER=ollama

# LLM Base URL
# - Ollama (default):  http://ollama:11434  (Docker internal) or http://localhost:11434 (host)
# - OpenAI:            https://api.openai.com
# - Anthropic:         https://api.anthropic.com
LLM_BASE_URL=http://ollama:11434

# Model name
# RTX 5060 Ti (16GB VRAM) recommended models:
#   qwen2.5-coder:14b       — best coding model for 16GB (default)
#   qwen2.5-coder:32b-q4_K_M — larger model, q4 quantized, tight fit
#   deepseek-coder-v2:16b   — strong alternative
#   llama3.1:8b             — fastest, lighter tasks
# Cloud models:
#   gpt-4o, gpt-4o-mini, claude-sonnet-4-20250514
LLM_MODEL=qwen2.5-coder:14b

# API key (only needed for OpenAI / Anthropic)
LLM_API_KEY=

# ── Server ───────────────────────────────
PORT=8000
MAX_CLIENTS=2

# ── Workspace ────────────────────────────
# Path on HOST to mount into container as /workspace
WORKSPACE_PATH=./../workspace
