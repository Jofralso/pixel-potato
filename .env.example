# ── LLM Provider ─────────────────────────
# Options: ollama | openai | anthropic
LLM_PROVIDER=ollama

# LLM Base URL
# - Ollama (default):  http://ollama:11434  (Docker internal) or http://localhost:11434 (host)
# - OpenAI:            https://api.openai.com
# - Anthropic:         https://api.anthropic.com
LLM_BASE_URL=http://ollama:11434

# Model name
# - Ollama:     qwen2.5-coder:14b, llama3.1:8b, deepseek-coder-v2:16b, codellama:34b
# - OpenAI:     gpt-4o, gpt-4o-mini
# - Anthropic:  claude-sonnet-4-20250514
LLM_MODEL=qwen2.5-coder:14b

# API key (only needed for OpenAI / Anthropic)
LLM_API_KEY=

# ── Server ───────────────────────────────
PORT=8000
MAX_CLIENTS=2

# ── Workspace ────────────────────────────
# Path on HOST to mount into container as /workspace
WORKSPACE_PATH=./../workspace
