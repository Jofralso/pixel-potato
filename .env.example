# ── LLM Provider ─────────────────────────
# Choose your AI backend: local (free) or cloud (paid)
#
# OPTION 1: 🏠 LOCAL (FREE) — Ollama on GPU
#   LLM_PROVIDER=ollama
#   LLM_BASE_URL=http://ollama:11434
#   LLM_MODEL=qwen2.5-coder:14b
#   LLM_API_KEY=
#   ✅ Free, private, runs locally with GPU
#   ❌ Needs GPU for good performance
#
# OPTION 2: 🧠 CLAUDE (PAID) — Anthropic API (~$0.003/1K input tokens)
#   LLM_PROVIDER=anthropic
#   LLM_BASE_URL=https://api.anthropic.com
#   LLM_MODEL=claude-3-5-sonnet-20241022
#   LLM_API_KEY=sk-ant-xxxxx (from console.anthropic.com)
#   ✅ Most intelligent, no GPU needed, works anywhere
#   ❌ Costs money per API call
#
# OPTION 3: 🤖 GPT (PAID) — OpenAI API (~$0.015/1K output tokens)
#   LLM_PROVIDER=openai
#   LLM_BASE_URL=https://api.openai.com
#   LLM_MODEL=gpt-4o
#   LLM_API_KEY=sk-xxxxx (from platform.openai.com)
#   ✅ Capable, large ecosystem
#   ❌ Costs money per API call

LLM_PROVIDER=ollama
LLM_BASE_URL=http://ollama:11434
LLM_MODEL=qwen2.5-coder:14b

# ── Server ───────────────────────────────
PORT=8000
MAX_CLIENTS=2

# ── Workspace ────────────────────────────
# Path on HOST to mount into container as /workspace
WORKSPACE_PATH=./../workspace

# ── MCP Server API Keys (optional) ──────
# These enable additional MCP servers. Leave blank to skip.

# GitHub: Create a PAT at https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=

# Brave Search: Free key at https://brave.com/search/api/
BRAVE_API_KEY=

# PostgreSQL: Connection string for database access
POSTGRES_CONNECTION_STRING=
